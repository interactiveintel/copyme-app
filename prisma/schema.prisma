generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ProfileType {
  personal
  social
  legal_entity
}

enum AccountTier {
  basic
  business_3
  business_7
  business_50
  ecommerce
}

enum Currency {
  USD
  EUR
}

enum DescriptionCategory {
  education
  business
  religion
  other
}

enum PlanType {
  basic
  business_3
  business_7
  business_50
  ecommerce
}

enum PeriodType {
  monthly
  quarterly
  annual
}

enum MessageType {
  text
  image
  voice
  video
  vap_transfer
  vap_request
  /// Tier-E call lifecycle bubble. The Message.content JSON carries
  /// {kind:"call", callType:"voice"|"video", status, callId,
  ///  durationSeconds?}. One Message per call lifecycle (not per
  ///  state change) — the existing row's content is updated as the
  ///  call's status flips.
  call
}

enum VapTransactionType {
  transfer
  payment
  deposit
  withdrawal
  fee
  refund
}

enum VapTransactionStatus {
  pending
  completed
  failed
  reversed
}

enum VapTier {
  standard
  premium
  merchant
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                String      @id @default(uuid()) @db.Uuid
  displayName       String      @map("display_name") @db.VarChar(45)
  profileType       ProfileType @default(personal) @map("profile_type")
  phoneHash         String?     @unique @map("phone_hash")
  emailHash         String?     @unique @map("email_hash")
  phoneEncrypted    Bytes?      @map("phone_encrypted")
  emailEncrypted    Bytes?      @map("email_encrypted")
  accountTier       AccountTier @default(basic) @map("account_tier")
  vapEnabled        Boolean     @default(false) @map("vap_enabled")
  preferredCurrency Currency    @default(USD) @map("preferred_currency")
  passwordHash      String      @map("password_hash")
  /// Vercel Blob URL for the user's avatar (S-105 / A1). Null until first
  /// upload; UI falls back to a deterministic gradient.
  avatarUrl         String?     @map("avatar_url") @db.VarChar(500)
  /// BCP-47 language tag — incoming messages in another language are
  /// translated to this on send (A3). Defaults to "en"; user can change in
  /// Profile → Privacy / Language.
  preferredLocale   String      @default("en") @map("preferred_locale") @db.VarChar(10)
  emailVerifiedAt   DateTime?   @map("email_verified_at")
  lastActivityAt    DateTime?   @map("last_activity_at")
  streakDays        Int         @default(0) @map("streak_days")
  streakLastDayAt   DateTime?   @map("streak_last_day_at")
  /// 8-char URL-safe referral code, generated lazily on first read.
  referralCode      String?     @unique @map("referral_code") @db.VarChar(16)
  /// User who invited this user (set once on register from ?ref=...).
  referredById      String?     @map("referred_by_id") @db.Uuid
  /// Stripe customer id, set on first paid checkout and persisted across
  /// subscriptions. Lets billing/refund + billing/cancel look up payments
  /// without the caller having to pass the id (closes the C8 503 caveat).
  stripeCustomerId      String? @unique @map("stripe_customer_id") @db.VarChar(64)
  /// Stripe subscription id for the user's CURRENT active subscription.
  /// Cleared by customer.subscription.deleted.
  stripeSubscriptionId  String? @map("stripe_subscription_id") @db.VarChar(64)
  createdAt         DateTime    @default(now()) @map("created_at")

  // Relations
  location        UserLocation?
  interests       UserInterest[]
  descriptions    UserDescription[]
  subscriptions   Subscription[]
  sentMessages    Message[]       @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  ownedGroups     Group[]         @relation("GroupOwner")
  groupMemberships GroupMember[]
  contacts        Contact[]       @relation("UserContacts")
  contactOf       Contact[]       @relation("ContactOf")
  vapAccount      VapAccount?
  sentTransactions     VapTransaction[] @relation("TransactionSender")
  receivedTransactions VapTransaction[] @relation("TransactionReceiver")
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  sessions                 Session[]
  recoveryFile             RecoveryFile?
  accountDeletion          AccountDeletion?
  suspensions              AccountSuspension[]
  pushSubscriptions        PushSubscription[]
  yogiPersonality          YogiPersonality?
  yogiMessages             YogiMessage[]
  yogiCostLogs             YogiCostLog[]
  translationCostLogs      TranslationCostLog[]
  blocksMade               UserBlock[]      @relation("UserBlocks")
  blockedBy                UserBlock[]      @relation("BlockedByUsers")
  reportsMade              UserReport[]     @relation("UserReportsMade")
  reportsAgainst           UserReport[]     @relation("UserReportsAgainst")
  ownedAds                 BusinessAd[]
  referredBy               User?            @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals                User[]           @relation("UserReferrals")

  @@index([accountTier])
  @@index([lastActivityAt])
  @@index([stripeSubscriptionId])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

enum AdStatus {
  draft
  pending_payment
  pending_review
  approved
  rejected
  paused
  expired
}

model BusinessAd {
  id              String    @id @default(uuid()) @db.Uuid
  ownerId         String    @map("owner_id") @db.Uuid
  brand           String    @db.VarChar(80)
  title           String    @db.VarChar(120)
  tagline         String?   @db.VarChar(200)
  body            String    @db.VarChar(700)
  imageUrl        String?   @map("image_url") @db.VarChar(500)
  ctaLabel        String    @default("Learn more") @map("cta_label") @db.VarChar(40)
  ctaUrl          String    @map("cta_url") @db.VarChar(500)
  category        String    @default("for-you") @db.VarChar(40)
  /// Lowercased interest keywords used for targeting; empty = "show to anyone".
  targetInterests Json?     @map("target_interests")
  /// Optional global region filter (matches UserLocation.globalArea), e.g. "Americas", "Europe".
  targetGlobalArea String?  @map("target_global_area") @db.VarChar(100)
  /// Optional region/state filter (matches UserLocation.region), e.g. "Florida", "Slovenia".
  targetRegion    String?   @map("target_region") @db.VarChar(100)
  status          AdStatus  @default(draft)
  /// Price the advertiser paid (stored in micro-USD, integer).
  priceMicroUsd   Int       @default(100000) @map("price_micro_usd")
  /// Stripe Checkout Session id (when payment via Stripe).
  stripeCheckoutId String?  @unique @map("stripe_checkout_id") @db.VarChar(120)
  /// Set once the advertiser has paid AND admin approved.
  activatedAt     DateTime? @map("activated_at")
  /// Ads expire 30 days after activation by default.
  expiresAt       DateTime? @map("expires_at")
  /// Admin who approved/rejected.
  reviewedById    String?   @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at")
  rejectionReason String?   @map("rejection_reason") @db.VarChar(300)
  /// Lifetime impression / click counters (denormalized; Sprint 10 will add a
  /// proper events table).
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  owner    User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  eventDays AdEventDay[]

  @@index([ownerId, status])
  @@index([status, activatedAt])
  @@index([category, status])
  @@map("business_ads")
}

model AdEventDay {
  adId        String   @map("ad_id") @db.Uuid
  /// UTC YYYY-MM-DD bucket.
  day         String   @db.VarChar(10)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  ad BusinessAd @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@id([adId, day])
  @@index([day])
  @@map("ad_event_days")
}

model UserBlock {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  reason    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedByUsers", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("user_blocks")
}

model UserReport {
  id           String   @id @default(uuid()) @db.Uuid
  reporterId   String   @map("reporter_id") @db.Uuid
  reportedId   String   @map("reported_id") @db.Uuid
  reason       String   @db.VarChar(50)
  details      String?  @db.VarChar(2000)
  status       String   @default("open") @db.VarChar(20)
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime @default(now()) @map("created_at")

  reporter User @relation("UserReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("UserReportsAgainst", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId, status])
  @@index([reporterId])
  @@index([status, createdAt])
  @@map("user_reports")
}

model YogiPersonality {
  userId          String   @id @map("user_id") @db.Uuid
  tone            String   @default("friendly") @db.VarChar(50)
  humor           Int      @default(5)
  empathy         Int      @default(7)
  totalChats      Int      @default(0) @map("total_chats")
  interests       Json?
  memorySummary   String?  @map("memory_summary")
  summarizedAt    DateTime? @map("summarized_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("yogi_personalities")
}

model YogiMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @db.VarChar(16)
  content   String
  mode      String   @default("text") @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("yogi_messages")
}

model YogiCostLog {
  userId          String   @map("user_id") @db.Uuid
  day             String   @db.VarChar(10)
  inputTokens     Int      @default(0) @map("input_tokens")
  outputTokens    Int      @default(0) @map("output_tokens")
  cacheReadTokens Int      @default(0) @map("cache_read_tokens")
  cacheWriteTokens Int     @default(0) @map("cache_write_tokens")
  costMicroUsd    Int      @default(0) @map("cost_micro_usd")
  callCount       Int      @default(0) @map("call_count")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, day])
  @@index([day])
  @@map("yogi_cost_logs")
}

/// Per-user per-day translation token spend (A3). Kept separate from
/// yogi_cost_logs so we can budget the two independently.
model TranslationCostLog {
  userId       String   @map("user_id") @db.Uuid
  day          String   @db.VarChar(10)
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costMicroUsd Int      @default(0) @map("cost_micro_usd")
  callCount    Int      @default(0) @map("call_count")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, day])
  @@index([day])
  @@map("translation_cost_logs")
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  /// Plaintext recipient email — stored only here (short-lived token row),
  /// so the verify endpoint can address the welcome email on first
  /// verification. The User row continues to hold only emailHash +
  /// emailEncrypted.
  email      String?   @db.VarChar(254)
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

// ---------------------------------------------------------------------------
// Phase 1.1 — Auth & Onboarding (S-101..S-110)
// ---------------------------------------------------------------------------

/// Phone-OTP challenge issued during sign-up or sign-in (S-101 / S-103).
/// One row per (phoneHash, attempt). Cleaned up by a cron job after expiry.
model PhoneOtp {
  id          String   @id @default(uuid()) @db.Uuid
  /// SHA-256 hex of the E.164 phone we sent the code to.
  phoneHash   String   @map("phone_hash") @db.VarChar(64)
  /// Bcrypt of the 6-digit code (so a DB leak doesn't expose live codes).
  codeHash    String   @map("code_hash")
  /// E.164 (encrypted at rest if that pipeline is wired; nullable).
  phoneEncrypted Bytes? @map("phone_encrypted")
  ipHash      String?  @map("ip_hash") @db.VarChar(64)
  attempts    Int      @default(0)
  consumedAt  DateTime? @map("consumed_at")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phoneHash, createdAt])
  @@index([expiresAt])
  @@map("phone_otps")
}

/// Active device/session list (S-106 + S-107).
/// Refresh tokens are stored as a hashed value here; rotation invalidates the old row.
model Session {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  /// Bcrypt of the refresh token. Single-use: rotated on each refresh.
  refreshHash     String   @map("refresh_hash")
  /// Stable per-device id (random uuid stored on the device).
  deviceId        String   @map("device_id") @db.Uuid
  deviceLabel     String?  @map("device_label") @db.VarChar(120)
  userAgent       String?  @map("user_agent") @db.VarChar(255)
  ipHash          String?  @map("ip_hash") @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at")
  lastUsedAt      DateTime @default(now()) @map("last_used_at")
  revokedAt       DateTime? @map("revoked_at")
  /// Set when a refresh-token replay is detected — UI surfaces a banner.
  replayDetectedAt DateTime? @map("replay_detected_at")
  expiresAt       DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([deviceId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Lost-phone recovery (S-108). One signed file per user, regenerated on demand.
model RecoveryFile {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  /// SHA-256 hex of the recovery secret printed in the file.
  secretHash    String   @map("secret_hash")
  /// Optional secondary verified phone (E.164 hash) for fallback recovery.
  secondaryPhoneHash String? @map("secondary_phone_hash") @db.VarChar(64)
  createdAt     DateTime @default(now()) @map("created_at")
  /// Set the moment recovery is exercised so we can rotate.
  consumedAt    DateTime? @map("consumed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recovery_files")
}

/// Hard-delete account (S-109). Holds 30-day grace before erasure.
model AccountDeletion {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @unique @map("user_id") @db.Uuid
  requestedAt  DateTime  @default(now()) @map("requested_at")
  /// requestedAt + 30 days; after this, an erase job purges PII.
  effectiveAt  DateTime  @map("effective_at")
  exportUrl    String?   @map("export_url") @db.VarChar(500)
  exportReadyAt DateTime? @map("export_ready_at")
  cancelledAt  DateTime? @map("cancelled_at")
  erasedAt     DateTime? @map("erased_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([effectiveAt, erasedAt])
  @@map("account_deletions")
}

// ---------------------------------------------------------------------------
// Phase 2.3 — Surveys (S-221..S-224)
// ---------------------------------------------------------------------------

model Survey {
  id              String   @id @default(uuid()) @db.Uuid
  ownerId         String   @map("owner_id") @db.Uuid
  title           String   @db.VarChar(120)
  description     String?  @db.VarChar(500)
  /// Up to 7 questions (Rule of 7).
  questions       Json
  /// Up to 7 interest tags for targeting.
  targetInterests Json?    @map("target_interests")
  status          String   @default("draft") @db.VarChar(16)
  rewardType      String   @default("none") @map("reward_type") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")

  responses SurveyResponse[]

  @@index([ownerId, status])
  @@index([status, createdAt])
  @@map("surveys")
}

model SurveyResponse {
  id        String   @id @default(uuid()) @db.Uuid
  surveyId  String   @map("survey_id") @db.Uuid
  /// Hashed user id — k-anonymity ≥ 7 enforced at read time (S-223).
  userHash  String   @map("user_hash") @db.VarChar(64)
  answers   Json
  createdAt DateTime @default(now()) @map("created_at")

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userHash])
  @@index([surveyId, createdAt])
  @@map("survey_responses")
}

/// Suspension lifecycle (S-175). Soft → hard with appeal.
model AccountSuspension {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  /// "soft" (read-only 7d) or "hard" (locked).
  level           String    @db.VarChar(10)
  reason          String    @db.VarChar(120)
  details         String?   @db.VarChar(2000)
  startedAt       DateTime  @default(now()) @map("started_at")
  /// For soft suspensions, the time at which it auto-escalates to hard.
  escalatesAt     DateTime? @map("escalates_at")
  liftedAt        DateTime? @map("lifted_at")
  appealUrl       String?   @map("appeal_url") @db.VarChar(500)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, liftedAt])
  @@map("account_suspensions")
}

model UserLocation {
  userId            String   @id @map("user_id") @db.Uuid
  globalArea        String?  @map("global_area") @db.VarChar(100)
  countryPhoneCode  String?  @map("country_phone_code") @db.VarChar(10)
  region            String?  @db.VarChar(100)
  cityZip           String?  @map("city_zip") @db.VarChar(100)
  localDescription  String?  @map("local_description") @db.VarChar(255)
  locationVerified  Boolean  @default(false) @map("location_verified")
  locationVisible   Boolean  @default(true) @map("location_visible")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([globalArea, region])
  @@index([countryPhoneCode])
  @@map("user_locations")
}

model UserInterest {
  userId       String @map("user_id") @db.Uuid
  slotNumber   Int    @map("slot_number") @db.SmallInt
  interestText String @map("interest_text") @db.VarChar(45)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, slotNumber])
  @@map("user_interests")
}

model UserDescription {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  category        DescriptionCategory
  level           String?             @db.VarChar(100)
  location        String?             @db.VarChar(255)
  institution     String?             @db.VarChar(255)
  typeDescription String?             @map("type_description") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@map("user_descriptions")
}

model Subscription {
  id                   String     @id @default(uuid()) @db.Uuid
  userId               String     @map("user_id") @db.Uuid
  plan                 PlanType   @default(basic)
  periodType           PeriodType @default(monthly) @map("period_type")
  autoRenew            Boolean    @default(true) @map("auto_renew")
  maxSearchResults     Int        @default(7) @map("max_search_results")
  maxContactsAtOnce    Int        @default(7) @map("max_contacts_at_once")
  maxContactsPerPeriod Int        @default(7) @map("max_contacts_per_period")
  maxSurveyParticipants Int       @default(7) @map("max_survey_participants")
  maxGroupSize         Int        @default(7) @map("max_group_size")
  startsAt             DateTime   @map("starts_at")
  expiresAt            DateTime   @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("subscriptions")
}

model Message {
  id                  String      @id @default(uuid()) @db.Uuid
  senderId            String      @map("sender_id") @db.Uuid
  receiverId          String      @map("receiver_id") @db.Uuid
  groupId             String?     @map("group_id") @db.Uuid
  type                MessageType @default(text)
  content             String?
  mediaUrls           Json?       @map("media_urls")
  durationSeconds     Int?        @map("duration_seconds")
  languageOriginal    String?     @map("language_original") @db.VarChar(10)
  languageTranslated  String?     @map("language_translated") @db.VarChar(10)
  translatedText      String?     @map("translated_text")
  createdAt           DateTime    @default(now()) @map("created_at")
  deliveredAt         DateTime?   @map("delivered_at")
  readAt              DateTime?   @map("read_at")
  expiresFromInboxAt  DateTime?   @map("expires_from_inbox_at")

  sender   User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  group    Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([receiverId, readAt])
  @@index([groupId, createdAt])
  @@index([expiresFromInboxAt])
  @@map("messages")
}

model Group {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(100)
  ownerId    String   @map("owner_id") @db.Uuid
  maxMembers Int      @default(7) @map("max_members")
  createdAt  DateTime @default(now()) @map("created_at")

  owner    User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  GroupMember[]
  messages Message[]

  @@index([ownerId])
  @@map("groups")
}

model GroupMember {
  groupId  String   @map("group_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model Contact {
  userId    String   @map("user_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  contact User @relation("ContactOf", fields: [contactId], references: [id], onDelete: Cascade)

  @@id([userId, contactId])
  @@index([contactId])
  @@map("contacts")
}

model VapAccount {
  userId              String   @id @map("user_id") @db.Uuid
  balance             Decimal  @default(0) @db.Decimal(12, 2)
  currency            Currency @default(USD)
  weeklyTransferTotal Decimal  @default(0) @map("weekly_transfer_total") @db.Decimal(12, 2)
  annualTransferTotal Decimal  @default(0) @map("annual_transfer_total") @db.Decimal(12, 2)
  tier                VapTier  @default(standard)
  taxRegistrationId   String?  @map("tax_registration_id") @db.VarChar(50)
  lastTransactionAt   DateTime? @map("last_transaction_at")
  virtualCardCount    Int      @default(0) @map("virtual_card_count")

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vap_accounts")
}

model VapTransaction {
  id         String               @id @default(uuid()) @db.Uuid
  senderId   String               @map("sender_id") @db.Uuid
  receiverId String?              @map("receiver_id") @db.Uuid
  type       VapTransactionType
  amount     Decimal              @db.Decimal(12, 2)
  currency   Currency             @default(USD)
  feeAmount  Decimal              @default(0) @map("fee_amount") @db.Decimal(12, 2)
  status     VapTransactionStatus @default(pending)
  createdAt  DateTime             @default(now()) @map("created_at")

  sender   User  @relation("TransactionSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User? @relation("TransactionReceiver", fields: [receiverId], references: [id], onDelete: SetNull)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([status])
  @@map("vap_transactions")
}

// ---------------------------------------------------------------------------
// Tier D Phase 1 — VAP money requests + split-bill coordination.
//
// Requests are the "ask me to pay" object. Lifecycle: pending → paid |
// declined | expired | canceled. Splits are just multiple requests
// sharing the same `splitGroupId`. The actual money movement still
// goes through VapTransaction; this table tracks intent + state.
// ---------------------------------------------------------------------------

model VapRequest {
  id                       String   @id @default(uuid()) @db.Uuid
  fromUserId               String   @map("from_user_id") @db.Uuid
  toUserId                 String   @map("to_user_id") @db.Uuid
  amount                   Decimal  @db.Decimal(12, 2)
  currency                 Currency @default(USD)
  note                     String?  @db.VarChar(140)
  /// pending | paid | declined | expired | canceled
  status                   String   @default("pending") @db.VarChar(20)
  /// Non-null when this row is part of a split-bill — all rows in the
  /// same split share the same splitGroupId.
  splitGroupId             String?  @map("split_group_id") @db.Uuid
  /// Set when status flips to "paid" — points at the VapTransaction
  /// that satisfied this request.
  fulfilledTransactionId   String?  @map("fulfilled_transaction_id") @db.Uuid
  /// Optional pointer to the in-chat Message row that surfaced this
  /// request to the recipient. Null for requests created without a
  /// linked thread message (e.g. legacy or admin paths).
  messageId                String?  @map("message_id") @db.Uuid
  expiresAt                DateTime @map("expires_at")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([toUserId, status])
  @@index([fromUserId])
  @@index([splitGroupId])
  @@map("vap_requests")
}

// ---------------------------------------------------------------------------
// Beta invite-code gate (v4.12.0).
//
// When BETA_INVITE_REQUIRED env var is set, /api/auth/phone/complete and
// /api/auth/register reject signups that don't supply a valid InviteCode.
// Codes can be one-shot (max_uses=1) or multi-use; redemption is tracked
// per-user so the same code can't burn through multiple slots from one
// account.
// ---------------------------------------------------------------------------

model InviteCode {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique @db.VarChar(32)
  /// Admin user id that minted the code. Null for system / seed-script
  /// codes.
  mintedById  String?   @map("minted_by_id") @db.Uuid
  /// Free-form note ("VIP friend of founder", "Slack outreach batch 1").
  note        String?   @db.VarChar(120)
  /// Maximum redemptions. 1 = single-use; large numbers for shared
  /// codes (e.g. a single press code).
  maxUses     Int       @default(1) @map("max_uses")
  /// Materialized counter — kept in sync with redemptions.length so the
  /// validate path can early-exit without joining.
  usedCount   Int       @default(0) @map("used_count")
  /// Optional expiry. Null = never.
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  redemptions InviteCodeRedemption[]

  @@map("invite_codes")
}

model InviteCodeRedemption {
  id           String     @id @default(uuid()) @db.Uuid
  inviteCodeId String     @map("invite_code_id") @db.Uuid
  /// User who redeemed it (the new account). FK omitted because users
  /// can be deleted but we want the redemption-history retained.
  userId       String     @map("user_id") @db.Uuid
  redeemedAt   DateTime   @default(now()) @map("redeemed_at")

  inviteCode   InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([inviteCodeId])
  @@map("invite_code_redemptions")
}

/// Tier-E call records. Each row is one call attempt — the lifecycle is
/// captured in `status` rather than spawning multiple rows.
/// 1:1 only in v4.15.0; v4.15.5 (Sprint 6) adds group calls via a
/// separate CallParticipant table that joins back here.
///
/// `room` is the LiveKit room name we joined; derived from a hash of
/// (callerId, calleeId, createdAt) so concurrent calls between the same
/// pair don't collide.
model Call {
  id              String   @id @default(uuid()) @db.Uuid
  callerId        String   @map("caller_id") @db.Uuid
  /// Primary callee for 1:1 calls. For group calls (isGroup=true) this
  /// is the FIRST invitee — kept for backwards compatibility with the
  /// 1:1-shaped API + existing inbox preview queries. Full participant
  /// list lives in CallParticipant.
  calleeId        String   @map("callee_id") @db.Uuid
  /// v4.15.12 (Sprint 6): true when 3+ participants total (caller +
  /// 2 or more callees). The 1:1 path keeps this false so old callers
  /// and inbox renderers don't need a code change to keep working.
  isGroup         Boolean  @default(false) @map("is_group")
  /// "voice" | "video" — set at create; doesn't change mid-call.
  callType        String   @default("voice") @map("call_type") @db.VarChar(10)
  /// "ringing" | "accepted" | "declined" | "missed" | "ended" | "failed"
  /// For groups, this is the AGGREGATE state — see CallParticipant for
  /// per-user state. The aggregate is "accepted" once at least one
  /// callee accepts, and "ended" only when all have left.
  status          String   @default("ringing") @db.VarChar(20)
  /// LiveKit room identifier. All peers join this name.
  room            String   @db.VarChar(64)
  /// Bound chat-thread Message row so the conversation can render the
  /// call as an inline bubble.
  messageId       String?  @map("message_id") @db.Uuid
  /// When the call left "ringing" — either via accept or terminal state.
  acceptedAt      DateTime? @map("accepted_at")
  /// When the call ended. Always set on terminal states.
  endedAt         DateTime? @map("ended_at")
  /// Wall-clock duration in seconds. Materialized at end so list views
  /// don't have to compute it.
  durationSeconds Int?     @map("duration_seconds")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  participants    CallParticipant[]

  @@index([calleeId, status])
  @@index([callerId])
  @@index([createdAt])
  @@map("calls")
}

/// v4.15.12 (Sprint 6): per-participant state for a Call.
///
/// For 1:1 calls we write a SINGLE row (the callee) so the same
/// queries work for both shapes. For groups, N rows — one per invitee.
/// The caller is NOT in this table (they're Call.callerId).
///
/// Rule of 7: enforced by the createGroupCall lib (max 6 callees + 1
/// caller = 7 total).
model CallParticipant {
  id          String    @id @default(uuid()) @db.Uuid
  callId      String    @map("call_id") @db.Uuid
  /// Nullable so ON DELETE SET NULL on the user FK can preserve call
  /// history (matches the calls.caller_fk pattern). Reads always
  /// filter status by userId before joining, so null userId rows just
  /// drop out of the "ringing for me?" poll.
  userId      String?   @map("user_id") @db.Uuid
  /// "ringing" | "accepted" | "declined" | "missed" | "left"
  /// "ended" is reserved for the Call aggregate — participants "left".
  status      String    @default("ringing") @db.VarChar(20)
  acceptedAt  DateTime? @map("accepted_at")
  /// When this participant left the room (or got marked missed). For
  /// declined/missed this equals updatedAt; for accepted-then-left it
  /// captures the actual leave time.
  leftAt      DateTime? @map("left_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  call        Call      @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@unique([callId, userId])
  @@index([userId, status])
  @@map("call_participants")
}
