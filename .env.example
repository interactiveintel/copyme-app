# CopyMe — environment variables.
# Copy to .env.local for development; set the same in Vercel for production.
# Items marked REQUIRED must be set or the matching feature returns 503.

# ---------------------------------------------------------------------------
# Database (REQUIRED — Vercel + Neon integration provides both automatically)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Unpooled URL — used by `prisma migrate deploy` (DDL) which can't use pooled.
DATABASE_URL_UNPOOLED=postgresql://user:pass@host-direct/db?sslmode=require

# ---------------------------------------------------------------------------
# Redis (REQUIRED — used for inbox cache, presence, AI rate limit)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Auth (REQUIRED in production)
# ---------------------------------------------------------------------------
# At least 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=your-secret-key-here-must-be-at-least-32-chars-long

# ---------------------------------------------------------------------------
# Anthropic / Yogi AI (REQUIRED to activate Yogi production mode)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional model overrides
# YOGI_MODEL=claude-opus-4-7
# YOGI_SUMMARY_MODEL=claude-haiku-4-5
# YOGI_DAILY_COST_CAP_USD=0.10

# ---------------------------------------------------------------------------
# Email (REQUIRED for verification, password reset, welcome, daily digest)
# ---------------------------------------------------------------------------
# Sign up at https://resend.com — generous free tier
RESEND_API_KEY=re_your-key-here
# Optional — defaults to "CopyMe <noreply@copyme.app>"
# MAIL_FROM=CopyMe <noreply@your-domain.com>
# MAIL_APP_NAME=CopyMe

# ---------------------------------------------------------------------------
# App URL — used in email links, OG images, Stripe redirects, push URLs
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://copyme-app.vercel.app

# ---------------------------------------------------------------------------
# Web Push (REQUIRED to activate browser notifications)
# ---------------------------------------------------------------------------
# Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=base64url-public-key
VAPID_PRIVATE_KEY=base64url-private-key
VAPID_SUBJECT=mailto:you@example.com

# ---------------------------------------------------------------------------
# Cron (REQUIRED for daily digest cron)
# ---------------------------------------------------------------------------
# Generate: openssl rand -hex 32
CRON_SECRET=long-random-string

# ---------------------------------------------------------------------------
# Analytics (OPTIONAL — without it, server-side events are silently dropped)
# ---------------------------------------------------------------------------
# POSTHOG_API_KEY=phc_your-project-api-key
# POSTHOG_HOST=https://us.i.posthog.com   # or https://eu.i.posthog.com

# ---------------------------------------------------------------------------
# Admin gate (REQUIRED to access /admin/metrics, /admin/ads)
# ---------------------------------------------------------------------------
# Comma-separated user UUIDs. Find your UUID by signing in and opening
# devtools → Application → Local Storage → copyme_auth → user.id
ADMIN_USER_IDS=uuid-of-founder-1,uuid-of-founder-2

# ---------------------------------------------------------------------------
# Stripe (REQUIRED for B2B ad payments)
# ---------------------------------------------------------------------------
# Test mode keys are fine for early launch
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Configure webhook endpoint in Stripe Dashboard:
#   URL:   https://your-app/api/webhooks/stripe
#   Event: checkout.session.completed

# ---------------------------------------------------------------------------
# Investor data room
# ---------------------------------------------------------------------------
# /pitch is public — no env vars required. (Previously gated by
# PITCH_PASSWORD; gate removed so investors can land directly.) The
# /pitch route is still excluded from robots.txt to keep it out of search
# indices, but is served to anyone with the link.

# ---------------------------------------------------------------------------
# Landing video (OPTIONAL — falls back to in-app DemoModal CTA)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_EXPLAINER_VIDEO_URL=https://www.youtube.com/embed/VIDEO_ID

# ---------------------------------------------------------------------------
# Waitlist (OPTIONAL — Google Sheet webhook)
# ---------------------------------------------------------------------------
# GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_ID/exec

# ---------------------------------------------------------------------------
# Sentry (OPTIONAL — error tracking + performance)
# ---------------------------------------------------------------------------
# Without these vars the app runs fine; observability calls become console
# logs only. Set the DSN to start sending events to Sentry. The auth token
# is only needed at build time (Vercel) for source-map upload.
#
# NEXT_PUBLIC_SENTRY_DSN=https://abc@o123.ingest.sentry.io/456
# SENTRY_ORG=interactiveintel
# SENTRY_PROJECT=copyme-app
# SENTRY_AUTH_TOKEN=sntrys_xxx_xxx               # build-only, mark as Secret
# SENTRY_ENVIRONMENT=production                  # auto-detected from VERCEL_ENV
